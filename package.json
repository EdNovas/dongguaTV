{
  "name": "dongguatv-enhanced-desktop",
  "version": "1.0.2",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "desktop": "electron .",
    "dist:desktop": "electron-builder --win"
  },
  "dependencies": {
    "@capacitor/screen-orientation": "^8.0.0",
    "@capacitor/status-bar": "^8.0.0",
    "axios": "^1.6.0",
    "better-sqlite3": "^12.5.0",
    "body-parser": "^1.20.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/cli": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "electron": "^32.3.3",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.donggua.tv.enhanced",
    "productName": "DongguaTV Enhanced",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "api/**",
      "public/**",
      "server.js",
      "main.js",
      "proxy-server.js",
      "db.template.json",
      "cloudflare-*.js",
      ".env.example",
      "package.json",
      "node_modules/**"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
